# OpenRouter (OpenAI-compatible Chat Completions)
# Use the raw API key only; do not prefix with "Bearer".
OPENROUTER_API_KEY=*********************************

# Use the API base root only (not /chat/completions).
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# Model route used by the backend LLM extraction step.
# DeepSeek models: deepseek/deepseek-r1, deepseek/deepseek-chat
# The backend automatically strips <think> tags from R1-style responses.
LLM_MODEL=deepseek/deepseek-chat

# Optional OpenRouter metadata headers.
OPENROUTER_SITE_URL=https://your-site.example
OPENROUTER_SITE_NAME=snv-PII-redact

# Optional timeout for the upstream model call.
# DeepSeek R1 can be slower due to the chain-of-thought reasoning pass.
LLM_REQUEST_TIMEOUT_SECONDS=120

# Number of output tokens per LLM call (covers reasoning + answer tokens for R1).
# Default 1200. Increase to 2000-3000 if R1 responses are frequently truncated.
LLM_MAX_OUTPUT_TOKENS=1200

# Backend debug logging (set to 1 to print detailed span/fuzzy diagnostics).
BACKEND_DEBUG_BLOCKS=0
