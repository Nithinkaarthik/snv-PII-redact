# OpenRouter (OpenAI-compatible Chat Completions)
# Use the raw API key only; do not prefix with "Bearer".
OPENROUTER_API_KEY=sk-or-v1-your-real-openrouter-key

# Use the API base root only (not /chat/completions).
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# Model route used by the backend LLM extraction step.
LLM_MODEL=nvidia/nemotron-3-super-120b-a12bdeepinfra/bf16

# Optional OpenRouter metadata headers.
OPENROUTER_SITE_URL=https://your-site.example
OPENROUTER_SITE_NAME=snv-PII-redact

# Optional timeout for the upstream model call.
LLM_REQUEST_TIMEOUT_SECONDS=60
